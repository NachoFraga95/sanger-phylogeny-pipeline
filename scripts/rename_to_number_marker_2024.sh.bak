#!/usr/bin/env bash
set -Eeuo pipefail
export LC_ALL=C

# Unified 2024 AB1 naming:
#   Regular:  YEAR_NN[-X]_MARKER_DIR[ _TAG].ab1
#   europu :  YEAR_europu_MARKER_DIR[ _TAG].ab1    (no number, no -X)
#
# -X = -C (CRISTIAN) / -J (JORGE). No generic fallback initial.
# Unknown NN => "XX".
#
# REQUIRED:
#   MAP_CSV, MAP_LABEL_COL (1-based "Código"), MAP_NUMBER_COL (1-based "N muestra")
# OPTIONAL:
#   YEAR_PREFIX=2024 (default)
#   SRC_GLOB="*.ab1"
#   EXTRAS_MAP="extras_map_2024.tsv"    # label<TAB>NN
#   PATTERN_MAP="pattern_map_2024.tsv"  # regex<TAB>NN (case-insensitive)

APPLY="${1:-}"
YEAR_PREFIX="${YEAR_PREFIX:-2024}"
SRC_GLOB="${SRC_GLOB:-*.ab1}"
EXTRAS_MAP="${EXTRAS_MAP:-extras_map_2024.tsv}"
PATTERN_MAP="${PATTERN_MAP:-pattern_map_2024.tsv}"

[[ -z "${MAP_CSV:-}" || ! -f "$MAP_CSV" ]] && { echo "ERROR: set MAP_CSV" >&2; exit 1; }

ts="$(date +%Y%m%d-%H%M%S)"
report="rename_report_${ts}.tsv"
undo="undo_renames_${ts}.sh"
echo -e "old_path\tnew_name\tstatus\treason" > "$report"
printf '#!/usr/bin/env bash\nset -Eeuo pipefail\n' > "$undo"; chmod +x "$undo"

# ---------- CSV → alias map ----------
declare -A SAMPLE2NUM
declare -A seen_numbers

LABEL_COL="${MAP_LABEL_COL:?set MAP_LABEL_COL}"
NUM_COL="${MAP_NUMBER_COL:?set MAP_NUMBER_COL}"

normalize(){ tr -d $'\r' | sed -e $'s/\t/,/g' -e 's/;/,/g'; }
trim(){ sed 's/^[ \t]*//;s/[ \t]*$//'; }

derive_aliases() {
  local raw="$1"
  local code="$(echo "$raw" | tr -d '\"' | tr -d '[:space:]')"
  local pre; pre="$(echo "$code" | sed -E 's/[0-9]{2,}$//')"   # strip trailing year digits
  if [[ "$pre" =~ ^(.+[^0-9])([0-9]{2})([A-Za-z]?)$ ]]; then
    local core="${BASH_REMATCH[1]}" nn="${BASH_REMATCH[2]}" let="${BASH_REMATCH[3]}"
    local al=( "${core}${nn}" "${core}.${nn}" )
    [[ -n "$let" ]] && al+=( "${core}${nn}${let}" "${core}.${nn}${let}" )
    if [[ "$core" =~ ^(.+)[a-z]{2}$ ]]; then
      local base="${BASH_REMATCH[1]}"
      al+=( "${base}${nn}" "${base}.${nn}" )
      [[ -n "$let" ]] && al+=( "${base}${nn}${let}" "${base}.${nn}${let}" )
    fi
    printf "%s\n" "${al[@]}" | awk '!seen[$0]++'
  fi
}

readarray -t RAW < <(cat "$MAP_CSV" | normalize)
((${#RAW[@]})) || { echo "ERROR: CSV appears empty" >&2; exit 1; }

for ((i=1;i<${#RAW[@]};i++)); do
  IFS=',' read -r -a row <<< "${RAW[$i]}"
  code="$(echo "${row[$((LABEL_COL-1))]:-}" | trim)"
  num_raw="${row[$((NUM_COL-1))]:-}"
  nd="$(echo "$num_raw" | tr -cd 0-9)"
  [[ -z "$code" || -z "$nd" ]] && continue
  nn=$(printf "%02d" "$nd"); seen_numbers["$nn"]=1
  while IFS= read -r alias; do [[ -n "$alias" ]] && SAMPLE2NUM["$alias"]="$nn"; done < <(derive_aliases "$code")
done

# ---------- overrides (EXTRAS_MAP) ----------
declare -A EXTRAS2NUM
if [[ -f "$EXTRAS_MAP" ]]; then
  while IFS=$'\t' read -r lab nn; do
    [[ -n "${lab:-}" && -n "${nn:-}" ]] && { EXTRAS2NUM["$lab"]="$nn"; seen_numbers["$nn"]=1; }
  done < <(grep -vE '^\s*#' "$EXTRAS_MAP" || true)
fi

# ---------- pattern map (regex → NN) ----------
declare -a PM_PAT=() PM_NN=()
if [[ -f "$PATTERN_MAP" ]]; then
  while IFS=$'\t' read -r pat nn; do
    [[ -n "${pat:-}" && -n "${nn:-}" ]] || continue
    PM_PAT+=("$pat"); PM_NN+=("$nn")
  done < <(grep -vE '^\s*#' "$PATTERN_MAP" || true)
fi

# ---------- marker / direction ----------
norm_marker_dir() {
  local S="${1^^}"

  # COI
  [[ "$S" =~ (LCO-?1490|FISHF1)        ]] && { echo COI_F;  return; }
  [[ "$S" =~ (HCO-?2198|FISHR1)        ]] && { echo COI_R;  return; }

  # 16S
  [[ "$S" =~ 16SAR                     ]] && { echo 16S_F;  return; }
  [[ "$S" =~ 16SBR                     ]] && { echo 16S_R;  return; }

  # 12S (variants + common typos)
  [[ "$S" =~ 12SA                      ]] && { echo 12S_F;  return; }
  [[ "$S" =~ 12SB                      ]] && { echo 12S_R;  return; }
  [[ "$S" =~ 12BR                      ]] && { echo 12S_R;  return; }                # tolerate "12br"
  [[ "$S" =~ 12S[^A-Z0-9]*12S?BR       ]] && { echo 12S_R;  return; }                # 12S-12br, 12S_12Sbr
  [[ "$S" =~ 12S[^A-Z0-9]*12S?A        ]] && { echo 12S_F;  return; }                # 12S-12Sa, 12S_12Sa

  # CytB
  [[ "$S" =~ (GLUDG-?L|MVZ15)          ]] && { echo CYTB_F; return; }
  [[ "$S" =~ (CB3-?H|EUPCB180)         ]] && { echo CYTB_R; return; }

  # Rhodopsin
  [[ "$S" =~ (RHODF|RHOD1A)            ]] && { echo RHO_F;  return; }
  [[ "$S" =~ (RHODR|RHOD1C)            ]] && { echo RHO_R;  return; }

  # CRY
  [[ "$S" =~ CRYB1LS                   ]] && { echo CRY_F;  return; }
  [[ "$S" =~ CRYB2LS                   ]] && { echo CRY_R;  return; }

  # POMC (prefer R if both present)
  if [[ "$S" =~ POMC ]]; then
    [[ "$S" =~ (^|[^A-Z0-9])R[0-9]*($|[^A-Z0-9]) ]] && { echo POMC_R; return; }
    [[ "$S" =~ (^|[^A-Z0-9])F[0-9]*($|[^A-Z0-9]) ]] && { echo POMC_F; return; }
  fi

  # D-loop / Control region (accept many shapes; determine direction by -L / -H)
  if [[ "$S" =~ (D[ -_]?LOOP|CONTROL) ]]; then
    [[ "$S" =~ (^|[^A-Z0-9])L($|[^A-Z0-9]) ]] && { echo DLOOP_F; return; }
    [[ "$S" =~ (^|[^A-Z0-9])H($|[^A-Z0-9]) ]] && { echo DLOOP_R; return; }
    echo DLOOP_?; return
  fi

  # Fallback families (unknown direction)
  [[ "$S" =~ (COI|COL|LCO|HCO)         ]] && { echo COI_?;  return; }
  [[ "$S" =~ 16S                       ]] && { echo 16S_?;  return; }
  [[ "$S" =~ (CYTB|CIT[ .-]?B|CB)      ]] && { echo CYTB_?; return; }
  [[ "$S" =~ 12S                       ]] && { echo 12S_?;  return; }
  [[ "$S" =~ (RHO|RHOD)                ]] && { echo RHO_?;  return; }
  [[ "$S" =~ POMC                      ]] && { echo POMC_?; return; }
  [[ "$S" =~ CRY                       ]] && { echo CRY_?;  return; }

  echo ""
}

# ---------- filename → label ----------
extract_label_from_fname() {
  local n="${1%.ab1}"

  # dotted token anywhere (Econt.01)
  if [[ "$n" =~ ([Ee][A-Za-z0-9]*)\.([0-9]{2}[A-Za-z]?) ]]; then
    echo "${BASH_REMATCH[1]}.${BASH_REMATCH[2]}"; return
  fi

  # scan dash tokens for compact label starting with 'E' (Esep01 / Erossj01h / Emicol01)
  IFS='-' read -r -a toks <<< "$n"
  for t in "${toks[@]}"; do
    if [[ "$t" =~ ^E[A-Za-z0-9]*([0-9]{2}[A-Za-z]?)$ ]]; then
      local tail="${BASH_REMATCH[1]}"; local stem="${t%$tail}"
      echo "${stem}${tail}"; return
    fi
  done

  # europu variants (case-insensitive)
  if [[ "$n" =~ ([Ee][Uu][Rr][Oo][Pp][Uu])([0-9]{1,2}) ]]; then
    echo "europu${BASH_REMATCH[2]}"; return
  fi
  if [[ "$n" =~ (^|[^A-Za-z0-9])([Ee][Uu][Rr][Oo][Pp][Uu])($|[^A-Za-z0-9]) ]]; then
    echo "europu"; return
  fi

  # fallback: token between first two dashes, but only if it looks like an E* label
  if [[ "$n" =~ ^[^-]*-([E][A-Za-z0-9]+(\.[0-9]{1,2})?)- ]]; then echo "${BASH_REMATCH[1]}"; return; fi

  echo ""
}

# ---------- experimenter tag ----------
experimenter_tag() {
  # returns "", or "-C"/"-J"
  local n="${1%.ab1}"
  IFS='-' read -r _ tok2 _ <<< "$n"
  [[ -z "${tok2:-}" ]] && { echo ""; return; }
  local u="${tok2^^}"
  case "$u" in
    CRISTIAN) echo "-C";;
    JORGE)    echo "-J";;
    *)        echo "";;
  esac
}

# ---------- label/filename → number/id ----------
infer_sample_id() {
  local base="$1"
  local label; label="$(extract_label_from_fname "$base")"

  # europu → literal id
  if [[ "$label" == "europu" || "$label" =~ ^europu[0-9]{1,2}$ ]]; then
    echo "europu"; return
  fi

  # 1) direct exact
  if [[ -n "$label" && ${SAMPLE2NUM[$label]+_} ]]; then echo "${SAMPLE2NUM[$label]}"; return; fi

  # 2) case-insensitive fallback
  if [[ -n "$label" ]]; then
    for k in "${!SAMPLE2NUM[@]}"; do
      if [[ "${k,,}" == "${label,,}" ]]; then echo "${SAMPLE2NUM[$k]}"; return; fi
    done
  fi

  # 3) locality-bridge
  if [[ -n "$label" && "$label" =~ ^([Ee][A-Za-z0-9]*)\.?([0-9]{2}[A-Za-z]?)$ ]]; then
    local stem="${BASH_REMATCH[1]}" nnpart="${BASH_REMATCH[2]}"
    for k in "${!SAMPLE2NUM[@]}"; do
      if [[ "$k" =~ ^${stem}[a-z]{2}${nnpart}$ || "$k" =~ ^${stem}[a-z]{2}\.${nnpart}$ ]]; then
        echo "${SAMPLE2NUM[$k]}"; return
      fi
    done
  fi

  # 4) explicit overrides (EXTRAS_MAP)
  if [[ -n "$label" && ${EXTRAS2NUM[$label]+_} ]]; then echo "${EXTRAS2NUM[$label]}"; return; fi

  # 5) pattern map (regex against full basename, case-insensitive)
  shopt -s nocasematch
  for ((i=0;i<${#PM_PAT[@]};i++)); do
    local pat="${PM_PAT[$i]}" pn="${PM_NN[$i]}"
    [[ "$base" =~ $pat ]] && { printf '%02d\n' "$pn"; shopt -u nocasematch; return; }
  done
  shopt -u nocasematch

  echo "XX"
}

unique_name() {
  local dir="$1" name="$2" stem ext cand i
  stem="${name%.ab1}"; ext=".ab1"; cand="$name"; i=2
  while [[ -e "$dir/$cand" ]]; do cand="${stem}_$i${ext}"; ((i++)); done
  echo "$cand"
}

# ---------- MAIN ----------
count_total=0; count_renamed=0; count_skipped=0; count_failed=0
shopt -s nullglob
files=( $SRC_GLOB )
echo "Scanning ${#files[@]} candidate files."

for f in "${files[@]}"; do
  ((count_total++))
  [[ -f "$f" ]] || { printf "%s\t\tfail\tmissing_file\n" "$f" >> "$report"; ((count_failed++)); continue; }
  base="$(basename "$f")"; dirn="$(dirname "$f")"

  # already unified?
  if [[ "$base" =~ ^(2024|24)_[0-9]{2}(-[A-Z])?_[A-Za-z0-9]+_([FR]|\?)\.ab1$ ]] \
     || [[ "$base" =~ ^2024_europu_[A-Za-z0-9]+_([FR]|\?)\.ab1$ ]]; then
    printf "%s\t%s\tskipped\talready_unified\n" "$f" "$base" >> "$report"; ((count_skipped++)); continue
  fi

  id="$(infer_sample_id "$base")"          # "NN", "XX" or "europu"
  md="$(norm_marker_dir "$base")"
  if [[ -z "$md" ]]; then
    echo "[fail]  $f (no_marker_found)"
    printf "%s\t\tfail\tno_marker_found\n" "$f" >> "$report"; ((count_failed++)); continue
  fi

  marker="${md%_*}"; dirc="${md#*_}"
  suffix=""; [[ "$dirc" == "?" ]] && suffix="_UNK"

  # tag (rep/run etc.)
  tag=""
  if [[ "$base" =~ (^|[^A-Za-z0-9])(rep[0-9]*|\(rep\))($|[^A-Za-z0-9]) ]]; then
    tag="_${BASH_REMATCH[2]}"; tag="${tag//\(/}"; tag="${tag//\)/}"
  fi
  if [[ "$base" =~ (^|[^A-Za-z0-9])(run[0-9]*)($|[^A-Za-z0-9]) ]]; then
    tag="_${BASH_REMATCH[2]}"
  fi

  exp="$(experimenter_tag "$base")"

  # build new name
  if [[ "$id" == "europu" ]]; then
    new="${YEAR_PREFIX}_europu_${marker}"
    [[ "$dirc" != "?" ]] && new+="_${dirc}"
    new+="${suffix}${tag}.ab1"
  else
    new="${YEAR_PREFIX}_${id}${exp}_${marker}"
    [[ "$dirc" != "?" ]] && new+="_${dirc}"
    new+="${suffix}${tag}.ab1"
  fi

  new="$(unique_name "$dirn" "$new")"

  if [[ "$APPLY" == "--apply" ]]; then
    mv -i -- "$f" "$dirn/$new"
    echo "[rename] $f -> $new"
    printf "%s\t%s\trenamed\t\n" "$f" "$new" >> "$report"
    echo "mv -i -- \"$dirn/$new\" \"$f\"" >> "$undo"
    ((count_renamed++))
  else
    echo "[dry]   $f -> $new"
    printf "%s\t%s\tdry-run\t\n" "$f" "$new" >> "$report"
  fi
done

echo
if [[ "$APPLY" == "--apply" ]]; then
  echo "Done."
else
  echo "Dry-run only. Re-run with:  $0 --apply"
fi
echo "Report: $report"
echo "Undo script: $undo"
echo "Summary: renamed=$count_renamed, skipped=$count_skipped, failed=$count_failed, total=$count_total"